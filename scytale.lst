     1                                  [BITS 64]
     2                                  
     3                                  SECTION .text
     4                                      GLOBAL scytale_decode
     5                                      GLOBAL scytale_encode
     6                                  
     7                                  ; unsigned char* scytale_decode(const char* encoded_payload, unsigned char* buf);
     8                                  scytale_decode:
     9 00000000 56                      	push rsi				; preserve rdi/rsi so we can use lod/sto
    10 00000001 57                      	push rdi
    11 00000002 4889CE                  	mov rsi, rcx				; encoded_payload
    12 00000005 4889D7                  	mov rdi, rdx				; buf
    13 00000008 66AD                    	lodsw					; skip 2-byte header
    14                                  
    15                                  .dmainloop:
    16 0000000A AC                      	lodsb					; grab the skip byte
    17 0000000B 84C0                    	test al, al				; did we hit a null terminator?
    18 0000000D 7427                    	jz .ddone
    19 0000000F 2C30                    	sub al, 0x30				; convert to int
    20 00000011 480FB6C8                	movzx rcx, al				; zero upper bits
    21 00000015 4801CE                  	add rsi, rcx				; hop over the skip value
    22 00000018 AC                      	lodsb					; get the first byte
    23 00000019 2C30                    	sub al, 0x30				; convert to int
    24 0000001B 3C09                    	cmp al, 9				; <=9 ?
    25 0000001D 7602                    	jbe .first				; hop over
    26 0000001F 2C07                    	sub al, 7				; get the letter
    27                                  .first:
    28 00000021 4188C0                  	mov r8b, al				; store the low nibble
    29 00000024 AC                      	lodsb					; get the second byte
    30 00000025 2C30                    	sub al, 0x30				; convert to int
    31 00000027 3C09                    	cmp al, 9				; <=9 ?
    32 00000029 7602                    	jbe .second				; hop over
    33 0000002B 2C07                    	sub al, 7				; get the letter
    34                                  .second:
    35 0000002D C0E004                  	shl al, 4				; shift the bits over
    36 00000030 4408C0                  	or al, r8b				; let our nibbles combine 
    37 00000033 AA                      	stosb					; add to buf
    38 00000034 EBD4                    	jmp .dmainloop				; all of this has happened before...
    39                                  
    40                                  .ddone:
    41 00000036 4889F8                  	mov rax, rdi				; set up the return pointer
    42 00000039 5F                      	pop rdi					; cleanup
    43 0000003A 5E                      	pop rsi
    44 0000003B C3                      	ret
    45                                  
    46                                  ; unsigned char* scytale_encode(char* dest, const char* src, size_t len);
    47                                  scytale_encode:
    48 0000003C 56                      	push rsi				; preserve rsi/rdi, so we can use lod/sto
    49 0000003D 57                      	push rdi
    50 0000003E 4889CF                  	mov rdi, rcx				; pointer to the destination buffer
    51 00000041 4889D6                  	mov rsi, rdx				; pointer to the source buffer
    52 00000044 0F31                    	rdtsc					; read the time stamp, for entropy
    53 00000046 E849000000              	call .converttohex			; store first byte of header garbage
    54 0000004B 0F31                    	rdtsc					; get some more entropy
    55 0000004D E842000000              	call .converttohex			; store second byte of header garbage
    56                                  .emainloop:
    57 00000052 0F31                    	rdtsc					; grab our entropy
    58 00000054 4883E007                	and rax, 7				; grab the last 3 bits (0-7)
    59 00000058 4889C1                  	mov rcx, rax				; store the garbage loop counter
    60 0000005B E834000000              	call .converttohex			; store the skip byte
    61 00000060 E309                    	jrcxz .continue				; if we have a 0 skip byte, no need to pad
    62                                  .paddingloop:
    63 00000062 0F31                    	rdtsc					; load our entropy
    64 00000064 E82B000000              	call .converttohex			; store the byte
    65 00000069 E2F7                    	loop .paddingloop
    66                                  .continue:
    67 0000006B AC                      	lodsb					; load the byte from the string
    68 0000006C 4889C2                  	mov rdx, rax				; so we don't lose it
    69 0000006F 48C1E804                	shr rax, 4				; get the last 4 bits
    70 00000073 E81C000000              	call .converttohex			; store the upper nibble
    71 00000078 4889D0                  	mov rax, rdx				; move the lower nibble
    72 0000007B E814000000              	call .converttohex			; store the lower nibble
    73 00000080 49FFC8                  	dec r8					; loop counter
    74 00000083 4D85C0                  	test r8, r8				; did we finish the loop?
    75 00000086 7402                    	jz .edone
    76 00000088 EBC8                    	jmp .emainloop				; all of this has hapened before
    77                                  .edone:
    78 0000008A 4831C0                  	xor rax, rax				; create a null terminator
    79 0000008D AA                      	stosb					; store it at the end
    80 0000008E 4889F8                  	mov rax, rdi				; store the return pointer for the end of the string
    81 00000091 5F                      	pop rdi					; cleanup
    82 00000092 5E                      	pop rsi
    83 00000093 C3                      	ret	
    84                                  .converttohex:
    85 00000094 240F                    	and al, 0x0F				; remove the top bits
    86 00000096 0430                    	add al, 0x30				; convert to a character
    87 00000098 3C39                    	cmp al, 0x39				; is the value >9?
    88 0000009A 7602                    	jbe .hexdone				; then we're done
    89 0000009C 0407                    	add al, 7				; convert to the proper A-F
    90                                  .hexdone:
    91 0000009E AA                      	stosb					; store the value
    92 0000009F C3                      	ret
    93                                  	
